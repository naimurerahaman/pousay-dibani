# =============================================================================
# Pousay Dibani — environment variables
# =============================================================================
# Copy this file to `.env` for local development.
# For production, set these in your hosting provider's env settings
# (Vercel → Project → Settings → Environment Variables).
#
# Never commit a real `.env` to git (it's in `.gitignore`).
# =============================================================================


# --- Database ---------------------------------------------------------------
# PostgreSQL connection string.
# Local:   postgresql://postgres:postgres@localhost:5432/pousay_dibani?schema=public
# Vercel:  use Vercel Postgres, Supabase, or Neon and paste the pooled URL here.
# Required in every environment.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pousay_dibani?schema=public"


# --- Public app URL ---------------------------------------------------------
# Absolute URL of the deployed app. Used in links, future emails, etc.
# Required in every environment.
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# --- Auth.js (NextAuth) -----------------------------------------------------
# Generate with:   openssl rand -base64 32
# Required in every environment. NEVER reuse a value across environments.
AUTH_SECRET="REPLACE_ME_WITH_OPENSSL_RAND_BASE64_32"

# Vercel / hosted environments must set this to "true".
# Locally, leave it as "true" too (it's required for Auth.js v5 to trust
# forwarded headers from `next start` / Vercel).
AUTH_TRUST_HOST="true"

# In production, Auth.js will automatically use secure cookies when this is
# not "development". You can override here if you need to force it on/off.
# AUTH_USE_SECURE_COOKIES="true"


# --- Initial admin user (used by the seed) ----------------------------------
# On a fresh database, running `npm run prisma:seed` will create a single
# OWNER admin with these credentials. After first login, change the password
# (or rotate by re-running the seed with new ADMIN_PASSWORD).
ADMIN_EMAIL="admin@pousaydibani.com"
# Use a strong password in production. Min 12 characters, mixed case + symbols.
ADMIN_PASSWORD="change-me-before-production"


# --- Error monitoring (optional) --------------------------------------------
# If set, server-side errors are reported to Sentry.
# SENTRY_DSN="https://...@sentry.io/..."
# SENTRY_AUTH_TOKEN="..."  # only needed for source map upload
# SENTRY_ORG="..."
# SENTRY_PROJECT="..."


# --- SMS provider (optional) ------------------------------------------------
# When a customer places an order, Pousay Dibani sends a confirmation SMS
# with the order number, total, and a tracking link.
#
# In development or until a real provider is wired up, the default
# `console` provider just logs the rendered message to stdout (visible in
# Vercel logs) and records the attempt in the SmsLog table.
#
# SMS_PROVIDER=console
#
# Future providers (not implemented yet) — the env keys below document
# what to set when adding one. The order-placement code will fail-soft
# (order is still placed) and surface a warning to the customer if the
# provider returns an error or no provider is configured.
#
# BulkSMS BD (https://bulksms.com.bd/):
#   SMS_PROVIDER=bulksms
#   BULKSMS_API_KEY="..."
#   BULKSMS_SENDER_ID="PousayDibani"
#
# Twilio (international):
#   SMS_PROVIDER=twilio
#   TWILIO_ACCOUNT_SID="..."
#   TWILIO_AUTH_TOKEN="..."
#   TWILIO_FROM_NUMBER="+1..."